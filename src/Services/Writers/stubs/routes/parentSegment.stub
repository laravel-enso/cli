import routeImporter from '@enso-ui/ui/src/modules/importers/routeImporter';

const routes = routeImporter.fromGlob(import.meta.glob('./${segment}/*.js', { eager: true }));
const Router = () => import('@enso-ui/ui/src/bulma/pages/Router.vue');


export default {
    path: '${relativePath}',
    component: Router,
    meta: {
        breadcrumb: '${breadcrumb}',
        route: '${permissionGroup}.index',
    },
    children: routes,
};
